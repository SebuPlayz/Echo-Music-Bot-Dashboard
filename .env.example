# Echo Bot + Dashboard — Environment Variables
# Copy to .env and fill in your real values. Never commit .env.

# ── Discord Bot ─────────────────────────────────────────────────
BOT_TOKEN=

# ── Dashboard (Discord OAuth2 Login) ────────────────────────────
# Get these from https://discord.com/developers/applications
# -> your application -> OAuth2 -> Client ID / Client Secret
DISCORD_CLIENT_ID=1526234943515263026
DISCORD_CLIENT_SECRET=fCgE_5q7bqaawqmwQI7BRlKLP9hbGqQ2

# Must EXACTLY match a Redirect URI you added in the Discord
# Developer Portal under OAuth2 -> Redirects.
# For local testing: http://localhost:8080/auth/callback
# For production (same host as the bot): https://yourdomain.com/auth/callback
DASHBOARD_REDIRECT_URI=http://localhost:2076/auth/callback

# Random long string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SESSION_SECRET=a3f8e9c2d1b47a6f8e0c9d2b1a4f7e6c3d8b9a2f1e4c7d0b3a6f9e2c5d8b1a4f

# Port the dashboard web server listens on
DASHBOARD_PORT=2076

# Set to "false" to run the bot without starting the dashboard
DASHBOARD_ENABLED=true
